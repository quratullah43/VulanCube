<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.VulanCube" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/blue_primary</item>
        <item name="colorPrimaryDark">@color/blue_dark</item>
        <item name="colorAccent">@color/blue_light</item>
        <item name="android:windowBackground">@color/blue_background</item>
        <item name="android:statusBarColor">@color/blue_surface</item>
        <item name="android:navigationBarColor">@color/blue_background</item>
    </style>

    <style name="Theme.VulanCube.Fullscreen" parent="Theme.VulanCube">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>
</resources>
